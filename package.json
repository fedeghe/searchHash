        "search object",
        "search literal"
    ],
    "author": "Federico Ghedina <fedeghe@gmail.com>",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/fedeghe/searchHash/issues"
    },
    "homepage": "https://github.com/fedeghe/searchHash#readme",
    "devDependencies": {
        "eslint": "^6.0.1",
        "jest": "^30.2.0",
        "jsdom": "^16.5.3",
        "malta": "^4.1.35",
        "malta-header-comment": "^1.0.5",
        "malta-jest": "^0.0.2",
        "malta-js-uglify": "^1.0.5"
    }
}
